# AI-miniSOC 环境变量配置

# Loki配置
LOKI_URL=http://192.168.0.30:3100
LOKI_RETENTION_DAYS=7

# Wazuh配置 (192.168.0.40)
WAZUH_API_URL=https://192.168.0.40:55000
WAZUH_API_USERNAME=your_wazuh_username
WAZUH_API_PASSWORD=your_wazuh_password

# OpenSearch配置
OPENSEARCH_URL=https://192.168.0.30:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=your_password_here

# Grafana配置
GRAFANA_URL=http://192.168.0.30:3000
GRAFANA_ADMIN_PASSWORD=admin

# AI服务配置 - 智谱AI (GLM)
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-flash
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# 邮件通知配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@aisoc.local

# 钉钉通知配置
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token
DINGTALK_SECRET=your_secret_here

# 微信通知配置
WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key

# 数据库配置 - PostgreSQL (192.168.0.42)
DB_HOST=192.168.0.42
DB_PORT=5432
DB_NAME=AI-miniSOC-db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT认证配置
JWT_SECRET_KEY=your_jwt_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 后端API配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://192.168.0.42:5173

# 前端配置
FRONTEND_PORT=5173

# 日志级别
LOG_LEVEL=info

# 时区
TZ=Asia/Shanghai

# 告警配置
ALERT_EMAIL_ENABLED=true
ALERT_DINGTALK_ENABLED=true
ALERT_WECHAT_ENABLED=false

# 数据保留配置
DATA_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=90

# 性能配置
MAX_LOG_ENTRIES=10000
QUERY_TIMEOUT=300
BATCH_SIZE=1000
