# Test Environment Configuration for AI-miniSOC E2E Tests
#
# All test services run on 192.168.0.42 (E2E testing platform)

# Database connection for testing
# Use PGPASSWORD environment variable for authentication
TEST_DATABASE_HOST=192.168.0.42
TEST_DATABASE_PORT=5432
TEST_DATABASE_USER=postgres
TEST_DATABASE_PASSWORD=PostgreSQL@2026
TEST_DATABASE_NAME=AI-miniSOC-testdb

# Connection command:
# PGPASSWORD='PostgreSQL@2026' psql -h 192.168.0.42 -U postgres -d AI-miniSOC-testdb

# API base URL for testing (same server)
TEST_API_BASE_URL=http://192.168.0.42:8000

# Frontend URL for testing (same server)
TEST_FRONTEND_URL=http://192.168.0.42:5173

# Test admin credentials
TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=admin123
