# Test Environment Configuration for AI-miniSOC E2E Tests
#
# This file contains environment variables for running Playwright E2E tests
# in the internal network environment (192.168.0.30)

# Database connection for testing
TEST_DATABASE_URL=postgresql://testuser:testpass@192.168.0.30:5432/ai_minisoc_test

# API base URL for testing
TEST_API_BASE_URL=http://192.168.0.30:8000

# Frontend URL for testing
TEST_FRONTEND_URL=http://192.168.0.30:5173

# Test admin credentials
TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=admin123
